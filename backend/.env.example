NODE_ENV=development
PORT=5000

# MongoDB
# Local: mongodb://127.0.0.1:27017/dor_cellular
# Atlas: mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/dor_cellular
MONGO_URI=mongodb://127.0.0.1:27017/dor_cellular

# JWT
# IMPORTANT: JWT_SECRET and JWT_REFRESH_SECRET MUST be different and at least 64 random chars.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace_me_with_long_random_string_one
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_me_with_long_random_string_two_DIFFERENT_FROM_ABOVE
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Frontend
FRONTEND_URL=http://localhost:5173

# Rate limit (15 min window, 200 requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# SMS / WhatsApp providers (stub by default).
# Options:
#  - stub                    -> just logs to console (dev)
#  - twilio                  -> needs TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
#  - meta_whatsapp           -> needs WHATSAPP_PHONE_ID, WHATSAPP_TOKEN
#  - inforu                  -> Israeli SMS gateway, needs INFORU_USERNAME, INFORU_PASSWORD
SMS_PROVIDER=stub
SMS_API_KEY=
WHATSAPP_API_URL=

# Auto-seed: when true, seeds the DB on boot if it is empty.
AUTO_SEED_IF_EMPTY=true

# Logging
LOG_LEVEL=info

# Anthropic AI assistant — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Project root (absolute path to the repo root — leave blank to auto-detect)
# PROJECT_ROOT=/srv/dor-cellular
